# URL pública da app (obrigatório em produção — anti Host-header poisoning)
# Local: http://localhost:3000
# Vercel: https://teu-dominio.vercel.app
AUTH_URL=http://localhost:3000

# Obrigatório em produção — string longa e aleatória (ex: openssl rand -base64 32)
# Também assina as URLs das fotos na assinatura de email
AUTH_SECRET=gera-uma-string-longa-aleatoria

# Assinaturas privadas por defeito.
# true = acesso sem login — BLOQUEADO em produção pelo middleware
SIGNATURES_PUBLIC=false

# Password só para desenvolvimento local (sem Google).
# Em produção é IGNORADA — obriga Google OAuth @ALLOWED_EMAIL_DOMAIN
ACCESS_PASSWORD=muda-esta-password

# Google OAuth (obrigatório em produção). Nunca commits o CLIENT_SECRET.
# Redirect URI: {AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAIL_DOMAIN=comparaja.pt

# Quem pode gerir o painel Admin e ver todas as assinaturas (emails separados por vírgula).
# Em produção: lista VAZIA = ninguém é admin (fail-closed). Define pelo menos um.
# Utilizadores normais só veem a própria assinatura.
# Ex: admin@comparaja.pt,it@comparaja.pt
ADMIN_EMAILS=

# Vercel Blob (opcional). O JSON de pessoas fica privado no Blob.
# BLOB_READ_WRITE_TOKEN=
