# URL pública da app (obrigatório em produção — anti Host-header poisoning)
# Local: http://localhost:3000
# Vercel: https://teu-dominio.vercel.app
AUTH_URL=http://localhost:3000

# Obrigatório em produção — string longa e aleatória (ex: openssl rand -base64 32)
# Também assina as URLs das fotos na assinatura de email
AUTH_SECRET=gera-uma-string-longa-aleatoria

# Assinaturas privadas por defeito.
# true = acesso sem login — BLOQUEADO em produção pelo middleware
SIGNATURES_PUBLIC=false

# Password só para desenvolvimento local (sem Google).
# Em produção é IGNORADA — obriga Google OAuth @ALLOWED_EMAIL_DOMAIN
ACCESS_PASSWORD=muda-esta-password

# Google OAuth (obrigatório em produção). Nunca commits o CLIENT_SECRET.
# Redirect URI: {AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAIL_DOMAIN=comparaja.pt

# Quem pode gerir o painel Admin e ver todas as assinaturas (emails separados por vírgula).
# Fail-closed: lista VAZIA = NINGUÉM é admin (dev e produção). Define pelo menos um.
# Login por password (só non-prod) NÃO concede admin — só emails nesta lista.
# Utilizadores normais só veem a própria assinatura.
# Ex: admin@comparaja.pt,it@comparaja.pt
ADMIN_EMAILS=

# --- Google Workspace (sync cargo/email + publicar assinatura no Gmail) ---
# 1) Cloud Console: Service Account + chave JSON
# 2) Ativar: Admin SDK API + Gmail API
# 3) Google Admin → Segurança → Delegação em todo o domínio
#    Client ID da SA + scopes:
#    https://www.googleapis.com/auth/admin.directory.user.readonly,
#    https://www.googleapis.com/auth/gmail.settings.basic
# 4) Super Admin para impersonar no sync:
GOOGLE_WORKSPACE_ADMIN_EMAIL=teu-admin@comparaja.pt
# RECOMENDADO: ficheiro JSON (evita o .env partir aspas/newlines)
# Coloca a chave em web/.secrets/google-sa.json  OU:
# GOOGLE_SERVICE_ACCOUNT_FILE=.secrets/google-sa.json
# Alternativa (frágil no Windows): JSON numa linha
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Nome da assinatura instalada no Gmail (marca ComparaMail)
GMAIL_SIGNATURE_NAME=MailCJ2026

# Vercel Blob (opcional). O JSON de pessoas fica privado no Blob.
# BLOB_READ_WRITE_TOKEN=
