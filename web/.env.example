# Obrigatório em produção — string longa e aleatória
AUTH_SECRET=gera-uma-string-longa-aleatoria

# Assinaturas privadas por defeito (true = acesso sem login — só para demos)
SIGNATURES_PUBLIC=false

# Password para aceder em local / fallback (sem Google)
# Não uses passwords fracas em produção
ACCESS_PASSWORD=muda-esta-password

# Google OAuth (opcional). Nunca commits o CLIENT_SECRET.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAIL_DOMAIN=comparaja.pt

# Quem pode gerir o painel com Google. Vazio = toda @comparaja.pt
# Com ACCESS_PASSWORD local, quem entra por password também é admin.
ADMIN_EMAILS=

# Vercel Blob (opcional). O JSON de pessoas fica privado no Blob.
# BLOB_READ_WRITE_TOKEN=
